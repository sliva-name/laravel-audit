{
    "name": "laravel-audit/package",
    "description": "Extensible Laravel code audit package with Pint, PHPStan/Larastan, and purpose-built analyzers.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "LaravelAudit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelAudit\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "nikic/php-parser": "^5.0",
        "symfony/process": "^6.4|^7.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelAudit\\AuditServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "pint": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
